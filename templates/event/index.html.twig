{% extends 'base.html.twig' %}

{% block title %}Event index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">Event list</h1>
    <a href="{{ path('app_event_new') }}" class="btn btn-primary">
        + New Event
    </a>
</div>

    <div class="card shadow-sm">
    <div class="card-body p-0">
        <!-- tabela -->
    </div>
</div>

    <table class="table table-striped table-hover shadow-sm bg-white rounded overflow-hidden">
        <thead>
            <tr>
                <th>Id</th>
                <th>OccurredAt</th>
                <th>Description</th>
                <th>Type</th>
                <th>Place</th>
                <th>Author</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>actions</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        {% for event in events %}
            <tr>
                <td>{{ event.id }}</td>
                <td>{{ event.occurredAt ? event.occurredAt|date('Y-m-d H:i') : '' }}</td>
                <td>{{ event.description }}</td>
                <td>{{ event.type }}</td>
                <td>{{ event.place }}</td>
                <td>{{ event.author }}</td>
                <td>{{ event.createdAt|date('Y-m-d H:i') }}</td>
                <td>{{ event.updatedAt ? event.updatedAt|date('Y-m-d H:i') : '' }}</td>
                <td>
    <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-sm btn-outline-primary">View</a>

    {% set isAdmin = is_granted('ROLE_ADMIN') %}
    {% set isOwner = (app.user and event.author == app.user.userIdentifier) %}
    {% set isFresh = (event.createdAt and event.createdAt > date('-24 hours')) %}

    {% if isAdmin or (isOwner and isFresh) %}
        <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="btn btn-sm btn-outline-warning">Edit</a>

        <form method="post"
      action="{{ path('app_event_delete', {id: event.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
            <button class="btn btn-outline-danger btn-sm">
    🗑 Delete
</button>
        </form>
    {% endif %}
</td>
<td>
  {% set status = event.status %}
  {% set badge =
    status == 'new' ? 'bg-primary' :
    status == 'in_progress' ? 'bg-warning text-dark' :
    status == 'closed' ? 'bg-success' :
    'bg-secondary'
  %}
  {% set label =
    status == 'new' ? 'Nowe' :
    status == 'in_progress' ? 'W trakcie' :
    status == 'closed' ? 'Zamknięte' :
    status
  %}
  <span class="badge {{ badge }}">{{ label }}</span>
</td>

            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    
{% endblock %}
