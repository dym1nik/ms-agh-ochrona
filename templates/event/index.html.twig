{% extends 'base.html.twig' %}

{% block title %}Event index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Event list</h1>
        <a href="{{ path('app_event_new') }}" class="btn btn-primary">
            + New Event
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover shadow-sm bg-white rounded overflow-hidden mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>OccurredAt</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Place</th>
                        <th>Author</th>
                        <th>CreatedAt</th>
                        <th>UpdatedAt</th>
                        <th>Actions</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                        {% set isOwner = currentUserIdentifier and event.author == currentUserIdentifier %}

                        <tr>
                            <td>{{ event.id }}</td>
                            <td>{{ event.occurredAt ? event.occurredAt|date('Y-m-d H:i') : '' }}</td>
                            <td>{{ event.description }}</td>
                            <td>{{ event.type }}</td>
                            <td>{{ event.place }}</td>
                            <td>{{ event.author }}</td>
                            <td>{{ event.createdAt|date('Y-m-d H:i') }}</td>
                            <td>{{ event.updatedAt ? event.updatedAt|date('Y-m-d H:i') : '' }}</td>
                            <td class="d-flex gap-2">
                                <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-sm btn-outline-primary">
                                    View
                                </a>

                                {% if isAdmin or (isOwner and event.isFresh) %}
                                    <a href="{{ path('app_event_edit', {id: event.id}) }}" class="btn btn-sm btn-outline-warning">
                                        Edit
                                    </a>

                                    {% include 'event/_delete_form.html.twig' with { event: event } %}
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge {{ event_status_badge_class(event) }}">
                                    {{ event_status_label(event) }}
                                </span>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="10">no records found</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}