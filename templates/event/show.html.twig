{% extends 'base.html.twig' %}

{% block title %}Event{% endblock %}

{% block body %}
    <h1>Event</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ event.id }}</td>
            </tr>
            <tr>
                <th>OccurredAt</th>
                <td>{{ event.occurredAt ? event.occurredAt|date('Y-m-d H:i') : '' }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ event.description }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ event.type }}</td>
            </tr>
            <tr>
                <th>Place</th>
                <td>{{ event.place }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ event.createdAt ? event.createdAt|date('Y-m-d H:i') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ event.updatedAt ? event.updatedAt|date('Y-m-d H:i') : '' }}</td>
            </tr>
        </tbody>
    </table>
    <div class="d-flex gap-2 mt-4">
    <a href="{{ path('app_event_index') }}" class="btn btn-outline-secondary">
    ← Back to list
</a>

    <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="btn btn-outline-warning">
    ✏ Edit
</a>

    {{ include('event/_delete_form.html.twig') }}
    </div>
{% endblock %}
